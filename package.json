{
  "name": "microsoft-todo-mcp-server-self-hosted",
  "version": "1.2.0",
  "description": "Self-hosted Microsoft To Do MCP server with OAuth dashboard and SQLite list registry — fixes personal account list limitations",
  "main": "dist/todo-index.js",
  "dependencies": {
    "@azure/msal-node": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.21.1",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "zod": "^3.25.76"
  },
  "scripts": {
    "build": "tsup",
    "start": "node dist/todo-index.js",
    "dev": "npm run build && node dist/todo-index.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,html,json}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,json}\" \"*.{json,md}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akkilesh-a/microsoft-todo-mcp-server-self-hosted.git"
  },
  "keywords": [
    "mcp",
    "cursor",
    "claude",
    "microsoft-todo",
    "todo",
    "self-hosted"
  ],
  "author": "Akkilesh A",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/akkilesh-a/microsoft-todo-mcp-server-self-hosted/issues"
  },
  "homepage": "https://github.com/akkilesh-a/microsoft-todo-mcp-server-self-hosted#readme",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.5",
    "@types/node": "^22.19.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "type": "module",
  "files": [
    "dist"
  ]
}
